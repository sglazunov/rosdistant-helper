{
	"manifest_version": 3,
	"name": "Помощь росдистантикам — Rosdistant Helper",
	"short_name": "Rosdistant Helper",
	"description": "Скачивает учебники и сохраняет тесты с платформы Росдистант в один клик — по ссылке или прямо с открытой страницы.",
	"version": "1.5.1",
	"icons": {
		"16": "icons/16.png",
		"32": "icons/32.png",
		"48": "icons/48.png",
		"128": "icons/128.png"
	},
	"action": {
		"default_popup": "popup.html",
		"default_title": "Помощь росдистантикам"
	},
	"permissions": ["scripting", "activeTab", "tabs", "downloads", "storage", "clipboardWrite"],
	"host_permissions": [
		"https://*.rosdistant.ru/*",
		"https://edu.rosdistant.ru/*"
	],
	"background": {
		"service_worker": "background.js"
	},
	"web_accessible_resources": [
		{
			"resources": ["lib/pdf.worker.min.js"],
			"matches": ["https://*.rosdistant.ru/*"]
		}
	]
}
