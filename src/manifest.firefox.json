{
	"manifest_version": 3,
	"name": "Помощь росдистантикам — Rosdistant Helper",
	"short_name": "Rosdistant Helper",
	"description": "Скачивает учебники и сохраняет тесты с платформы Росдистант в один клик — по ссылке или прямо с открытой страницы.",
	"version": "1.3.0",
	"icons": {
		"16": "icons/16.png",
		"32": "icons/32.png",
		"48": "icons/48.png",
		"128": "icons/128.png"
	},
	"action": {
		"default_popup": "popup.html",
		"default_title": "Помощь росдистантикам"
	},
	"permissions": ["scripting", "activeTab", "tabs", "downloads", "storage", "clipboardWrite"],
	"host_permissions": [
		"https://*.rosdistant.ru/*",
		"https://edu.rosdistant.ru/*"
	],
	"background": {
		"scripts": ["lib/qpdf.js", "background.js"]
	},
	"content_security_policy": {
		"extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
	},
	"browser_specific_settings": {
		"gecko": {
			"id": "rosdistant-helper@opiums.helper",
			"strict_min_version": "115.0"
		}
	}
}
